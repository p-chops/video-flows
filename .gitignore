# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
*.so

# Virtual environments
.venv/
venv/
env/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Pipeline working files and output
work/
output/
input/
source/

# Media files (never commit large binaries)
*.mp4
*.avi
*.mkv
*.mov
*.webm
*.wav
*.mp3
*.flac

# Shader packs — track starter (ships with repo), ignore personal packs
packs/*
!packs/starter/

# Docs (local only)
docs/

# Scripts — track user-facing tools, ignore personal/dev scripts
scripts/*
!scripts/create_pack.py
!scripts/generate_stacks.py

# Backups
backup/

# Prefect
.prefect/
